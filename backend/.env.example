# ============================================
# PersonalTeachers 环境变量配置
# ============================================
# 复制此文件为 .env 并填入你的API密钥

# ============================================
# AI模型API密钥
# ============================================

# 智谱AI GLM API (GLM4.7)
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPUAI_API_KEY=your-key-here

# DeepSeek API
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MiniMax API
# 获取地址: https://www.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=your-key-here
MINIMAX_GROUP_ID=your-group-id-here

# ============================================
# 邮件配置 (SMTP)
# ============================================

# SMTP服务器地址
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 邮件账号和密码
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# 发件人信息
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=PersonalTeachers

# ============================================
# 数据库配置
# ============================================

# SQLite数据库路径 (相对于backend目录)
DATABASE_URL=sqlite:///storage/quotes.db

# ============================================
# Web服务配置
# ============================================

# 服务端口
PORT=8000

# 服务Host (0.0.0.0 允许外部访问)
HOST=127.0.0.1

# 调试模式 (生产环境设为false)
DEBUG=true

# ============================================
# 日志配置
# ============================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=storage/logs/app.log
