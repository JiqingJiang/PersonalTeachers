# PersonalTeachers v2 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================
# 必填配置
# ============================================

# 安全密钥（生产环境务必修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# 管理员账号（首次启动自动创建，之后修改不会生效）
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# SMTP 邮件（用于发送验证码，QQ邮箱推荐）
# QQ邮箱授权码获取：设置 → 账户 → POP3/SMTP → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USERNAME=your-email@qq.com
SMTP_PASSWORD=your-smtp-authorization-code

# ============================================
# 可选配置（一般无需修改）
# ============================================

APP_NAME=PersonalTeachers
DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./storage/personal_teachers.db
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
