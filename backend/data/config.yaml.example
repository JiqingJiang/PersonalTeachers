# PersonalTeachers 用户配置模板
# 复制此文件为 config.yaml 并填入你的个人信息

advanced:
  concurrent_generation: 3
  request_timeout: 30
  save_raw_responses: false
  verbose_logging: false

ai_model:
  fallback_order:
  - glm
  - deepseek
  - gemini
  - minimax
  primary: glm

delivery:
  enabled: true
  time: '23:00'
  timezone: Asia/Shanghai

experimental:
  auto_quality_scoring: false
  feedback_collection: true
  recommendation_algorithm: false

generation:
  age_diversity: true
  deduplication:
    days: 7
    enabled: true
  max_length: 200
  min_length: 80
  quality:
    max_retries: 3
    min_quality_score: 3.0
  quote_count: 10

# 关键词权重 - 根据你感兴趣的主题调整
keyword_weights:
  专注: 1
  习惯: 1
  伴侣: 1
  信仰: 1
  信任: 1
  债务: 1
  健康: 1
  公平: 1
  创造: 1
  原谅: 1
  告别: 1
  命运: 1
  和解: 1
  因果: 1
  复利: 1
  天赋: 1
  失败: 1
  嫉妒: 1
  孤独: 1
  学习: 1
  孩子: 1
  安全感: 1
  尊重: 1
  归属感: 1
  性: 0
  情绪: 1
  意义: 1
  房子: 1
  执行: 1
  改变: 1
  无常: 1
  时间: 1
  朋友: 1
  权力: 1
  欲望: 1
  死亡: 1
  焦虑: 1
  爱: 1
  父母: 1
  生存: 1
  真理: 1
  睡眠: 1
  竞争: 1
  耐心: 1
  自我: 1
  自由: 1
  衰老: 1
  认知: 1
  责任: 1
  贫穷: 1
  资产: 1
  选择: 1
  逻辑: 1
  遗忘: 1
  遗憾: 1
  金钱: 1
  阶层: 1
  面子: 1
  风险: 1
  食物: 0.3

# 导师类型偏好
mentor_preferences:
  common: 0.1        # 普通百姓
  future_self: 0.2   # 未来自己
  historical: 0.3    # 历史人物
  modern: 0.4        # 现代人物

# 用户个人信息
user:
  age: 24
  bio: 你的个人简介
  current_state:
    confusion: 当前最大的困惑
    expectation: 你期望的方向
    status: 当前状态描述
  email: your-email@example.com
  name: 你的名字
  profession: 你的职业/专业
