<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- 服务唯一标识 -->
    <key>Label</key>
    <string>com.personalteachers.agent</string>

    <!-- 服务要运行的脚本 -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/jiqing/Desktop/Project/vibe-coding/PersonalTeachers/scripts/start.sh</string>
        <string>production</string>
    </array>

    <!-- 工作目录 -->
    <key>WorkingDirectory</key>
    <string>/Users/jiqing/Desktop/Project/vibe-coding/PersonalTeachers/backend</string>

    <!-- 环境变量 -->
    <key>EnvironmentVariables</key>
    <dict>
        <!-- 代理支持（如果需要） -->
        <key>http_proxy</key>
        <string></string>
        <key>https_proxy</key>
        <string></string>
        <key>no_proxy</key>
        <string>localhost,127.0.0.1</string>
    </dict>

    <!-- 运行用户 -->
    <key>UserName</key>
    <string>jiqing</string>

    <!-- 标准输出和错误输出日志 -->
    <key>StandardOutPath</key>
    <string>/Users/jiqing/Desktop/Project/vibe-coding/PersonalTeachers/backend/storage/logs/launchd.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jiqing/Desktop/Project/vibe-coding/PersonalTeachers/backend/storage/logs/launchd.stderr.log</string>

    <!-- 在加载时立即启动 -->
    <key>RunAtLoad</key>
    <true/>

    <!-- 服务崩溃时自动重启（间隔10秒以上）-->
    <key>KeepAlive</key>
    <dict>
        <!-- 进程退出时重启 -->
        <key>SuccessfulExit</key>
        <false/>
        <!-- 崩溃时重启 -->
        <key>Crashed</key>
        <true/>
    </dict>

    <!-- 重启延迟（秒），避免频繁重启 -->
    <key>ThrottleInterval</key>
    <integer>10</integer>

    <!-- 网络变化时重启服务 -->
    <key>WatchPaths</key>
    <array>
        <!-- 监控网络配置变化 -->
        <string>/Library/Preferences/SystemConfiguration/NetworkInterfaces.plist</string>
    </array>

    <!-- 每小时检查一次服务状态 -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- 进程退出时（即使成功退出）也重启 -->
    <key>ExitTimeOut</key>
    <integer>30</integer>

</dict>
</plist>
