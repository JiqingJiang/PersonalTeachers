# PersonalTeachers .gitignore

# ============================================
# 环境变量和敏感信息
# ============================================
.env
backend/.env
**/.env.local
backend/data/config.yaml

# ============================================
# Python
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ============================================
# 虚拟环境
# ============================================
venv/
ENV/
env/
.venv

# ============================================
# 数据库和存储
# ============================================
backend/storage/*.db
backend/storage/*.db-journal
backend/storage/logs/*.log
backend/storage/cache/

# ============================================
# IDE
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# 测试和覆盖率
# ============================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# ============================================
# 临时文件
# ============================================
*.tmp
*.bak
*.log
*.cache

# ============================================
# 前端构建产物
# ============================================
frontend/dist/
admin/dist/
frontend/node_modules/
admin/node_modules/
